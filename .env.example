# Local environment template for LinguaFoundry.
# Copy this file to .env and fill in values locally. Do not commit .env.

# Telegram bot token for services/bot when implemented.
TELEGRAM_BOT_TOKEN=

# Backend API base URL used by services/bot.
API_BASE_URL=http://localhost:8000

# Telegram long-polling timeout in seconds for services/bot.
TELEGRAM_POLL_TIMEOUT=30

# Runtime environment name, for example: development, test, production.
APP_ENV=development

# Log verbosity for local development.
LOG_LEVEL=INFO

# PostgreSQL container settings for Docker Compose.
POSTGRES_USER=linguafoundry
POSTGRES_PASSWORD=linguafoundry
POSTGRES_DB=linguafoundry
POSTGRES_PORT=5432

# Host port used by the API service in Docker Compose.
API_PORT=8000

# PostgreSQL database URL for host-side services/api runs.
# Add local credentials in .env when your PostgreSQL setup requires them.
DATABASE_URL=postgresql+asyncpg://localhost:5432/linguafoundry

# Set to true to log SQL statements during local API development.
DATABASE_ECHO=false
