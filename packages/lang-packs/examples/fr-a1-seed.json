            {
              "id": "greetings",
              "title": "Greetings",
              "description": "Recognize and produce common French greetings.",
              "order": 0,
              "learning_objectives": [
                "Say hello with bonjour.",
                "Say goodbye with au revoir.",
                "Choose a greeting for the time of day."
              ],
              "vocabulary": [
                {
                  "term": "bonjour",
                  "translation": "hello",
                  "part_of_speech": "interjection"
                },
                {
                  "term": "bonsoir",
                  "translation": "good evening",
                  "part_of_speech": "interjection"
                },
                {
                  "term": "au revoir",
                  "translation": "goodbye",
                  "part_of_speech": "interjection"
                }
              ],
              "exercises": [
                {
                  "id": "choose-hello",
                  "type": "multiple_choice",
                  "order": 0,
                  "prompt": {
                    "text": "Which phrase means hello?",
                    "instruction": "Choose one answer."
                  },
                  "options": [
                    {
                      "id": "bonjour",
                      "text": "bonjour"
                    },
                    {
                      "id": "au-revoir",
                      "text": "au revoir"
                    },
                    {
                      "id": "merci",
                      "text": "merci"
                    }
                  ],
                  "answers": [
                    {
                      "value": "bonjour",
                      "notes": "References the correct option ID."
                    }
                  ],
                  "explanation": {
                    "text": "Bonjour is the standard French greeting for hello.",
                    "notes": [
                      "Au revoir means goodbye."
                    ]
                  },
                  "tags": ["recognition", "greetings"]
                },
                {
                  "id": "translate-goodbye",
                  "type": "translation",
                  "order": 1,
                  "prompt": {
                    "text": "Translate: goodbye",
                    "instruction": "Type the French phrase."
                  },
                  "answers": [
                    {
                      "value": "au revoir",
                      "normalized_value": "au revoir",
                      "case_sensitive": false
                    }
                  ],
                  "explanation": {
                    "text": "Au revoir is used to say goodbye.",
                    "remediation": "Review the greetings vocabulary and try again."
                  },
                  "tags": ["production", "greetings"]
                },
                {
                  "id": "flashcard-good-evening",
                  "type": "flashcard",
                  "order": 2,
                  "prompt": {
                    "text": "bonsoir",
