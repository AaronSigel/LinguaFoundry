{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linguafoundry.local/schemas/language-pack.schema.json",
  "title": "LinguaFoundry Language Pack",
  "description": "Format for language learning content packs containing levels, topics, lessons, exercises, answers, and explanations.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "pack_id", "language", "levels"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "pack_id": {
      "$ref": "#/$defs/slug"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "language": {
      "$ref": "#/$defs/language"
    },
    "source_language": {
      "$ref": "#/$defs/language"
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/level"
      }
    }
  },
  "$defs": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[-_][a-z0-9]+)*$"
    },
    "language_code": {
      "type": "string",
      "pattern": "^[a-z]{2,3}(?:-[A-Za-z0-9]{2,8})*$"
    },
    "language": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "name", "native_name", "direction"],
      "properties": {
        "code": {
          "$ref": "#/$defs/language_code"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "native_name": {
          "type": "string",
          "minLength": 1
        },
        "direction": {
          "type": "string",
          "enum": ["ltr", "rtl"]
        }
      }
    },
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "order", "topics"],
      "properties": {
        "id": {
          "type": "string",
          "enum": ["A1", "A2", "B1", "B2", "C1", "C2"]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "order": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "topics": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/topic"
          }
        }
      }
    },
    "topic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "order", "lessons"],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "order": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/lesson"
          }
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "order", "exercises"],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "order": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "learning_objectives": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "vocabulary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vocabulary_item"
          }
        },
        "exercises": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/exercise"
          }
        }
      }
    },
    "vocabulary_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["term", "translation"],
      "properties": {
        "term": {
          "type": "string",
          "minLength": 1
        },
        "translation": {
          "type": "string",
          "minLength": 1
        },
        "transliteration": {
          "type": "string"
        },
        "part_of_speech": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "order",
        "prompt",
        "answers",
        "explanation"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug"
        },
        "type": {
          "type": "string",
          "enum": [
            "flashcard",
            "multiple_choice",
            "text_input",
            "translation",
            "listening",
            "ordering"
          ]
        },
        "order": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "prompt": {
          "$ref": "#/$defs/prompt"
        },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/option"
          }
        },
        "answers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/answer"
          }
        },
        "explanation": {
          "$ref": "#/$defs/explanation"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/slug"
          }
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string"
        },
        "examples": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "audio": {
          "type": "string",
          "format": "uri-reference"
        }
      }
    },
    "option": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {
          "$ref": "#/$defs/slug"
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value"],
      "properties": {
        "value": {
          "type": "string",
          "minLength": 1
        },
        "normalized_value": {
          "type": "string",
          "minLength": 1
        },
        "case_sensitive": {
          "type": "boolean",
          "default": false
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "explanation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "remediation": {
          "type": "string"
        }
      }
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    }
  }
}
